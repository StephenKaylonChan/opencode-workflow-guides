{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/architecture/README.md",
    "docs/development/getting-started.md",
    "docs/roadmap/README.md"
  ],
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "git push *": "deny",
      "git reset --hard*": "deny",
      "rm *": "deny"
    },
    "skill": {
      "*": "ask",
      "docs-refresh": "allow",
      "audit-checklist": "allow",
      "spec-review": "allow",
      "testing-trophy": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny"
      }
    },
    "build": {
      "permission": {
        "edit": "ask"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", ".next/**"]
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".json", ".md"]
    }
  },
  "snapshot": true
}
